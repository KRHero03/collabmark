DEBUG=true

MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=collabmark

REDIS_URL=redis://localhost:6379

GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

JWT_SECRET_KEY=replace-with-a-secure-random-string-of-at-least-32-characters
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:8000"]

# Notifications (use Mailpit for local dev — UI at http://localhost:8025)
NOTIFICATIONS_ENABLED=true
NOTIFICATION_EMAIL_PROVIDER=smtp
NOTIFICATION_FROM_EMAIL=noreply@collabmark.local
SMTP_HOST=localhost
SMTP_PORT=1025
NOTIFICATION_DELAY_SECONDS=10
# For Resend (production):
# NOTIFICATION_EMAIL_PROVIDER=resend
# RESEND_API_KEY=re_xxxxx
# NOTIFICATION_FROM_EMAIL=noreply@collabmark.app
